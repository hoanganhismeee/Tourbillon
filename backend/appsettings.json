{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Hangfire": "Warning",
        "StackExchange.Redis": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/tourbillon-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"],
    "Properties": {
      "Application": "Tourbillon"
    }
  },
  "AllowedHosts": "*",
  
  "ConnectionStrings": {
    "DefaultConnection": "",
    "PgAdminConnection": ""
  },
  
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableSsl": true,
    "FromName": "Tourbillon"
  },

  "Cloudinary": {
  },

  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false"
  },

  "AiService": {
    "BaseUrl": "http://localhost:5000"
  },

  "Authentication": {
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    }
  },

  "AppSettings": {
    "FrontendBaseUrl": "http://localhost:3000"
  },

  "AdminSettings": {
    "SeedAdminEmail": ""
  },

  "ChatSettings": {
    "DailyLimit": 5,
    "DisableLimitInDev": true
  },

  "WatchFinderSettings": {
    "DailyLimit": 5,
    "DisableLimitInDev": true
  },

  "AWS": {
    "Region": "ap-southeast-2",
    "BucketName": "tourbillon-assets-brandon-839070695588-ap-southeast-2-an",
    "CloudFrontDomain": "d2lauyid2w6u9c.cloudfront.net"
  },

  "Storage": {
    "Provider": "S3"
  }
}
